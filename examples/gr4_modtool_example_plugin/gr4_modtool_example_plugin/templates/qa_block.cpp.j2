// qa_{{ block_name }}.cpp — generated by gr4-modtool-example-plugin
//
// This file is an example template override.  It is identical to the built-in
// qa_block.cpp.j2 except for this comment block, which demonstrates that the
// override mechanism is working.  Replace the body below with your
// organisation's standard test boilerplate.
//
// Available context variables (same as the built-in):
//   block_name        — CamelCase struct name  (e.g. "LowPassFilter")
//   namespace         — Full C++ namespace      (e.g. "gr::mymod::dsp")
//   group             — Group name or ""        (e.g. "dsp")
//   gr4_include_prefix— Include path prefix     (e.g. "gnuradio-4.0")
//   first_type        — First template type     (e.g. "float")
//   first_port_type   — Type of first in-port
//   first_out_type    — Type of first out-port
//   in_ports          — List of {name, type} dicts
//   out_ports         — List of {name, type} dicts
//   needs_graph_test  — bool: True when the block has ≥1 in and ≥1 out port

#include <boost/ut.hpp>
{% if group %}#include <{{ gr4_include_prefix }}/{{ group }}/{{ block_name }}.hpp>
{% else %}#include <{{ gr4_include_prefix }}/{{ block_name }}.hpp>
{% endif %}
{% if needs_graph_test %}
#include <gnuradio-4.0/testing/NullSources.hpp>
#include <gnuradio-4.0/Graph.hpp>
#include <gnuradio-4.0/Scheduler.hpp>
{% endif %}

using namespace boost::ut;

const boost::ut::suite<"{{ block_name }}"> {{ block_name | lower }}Tests = [] {
    "basic instantiation"_test = [] {
        {{ namespace }}::{{ block_name }}<{{ first_type }}> blk;
        blk.init(blk.progress);
        expect(true);
    };

    // TODO: add functional tests
};
{% if needs_graph_test %}

const boost::ut::suite<"{{ block_name }} graph"> {{ block_name | lower }}GraphTests = [] {
    "graph: runs without error"_test = [] {
        gr::Graph graph;
{% for port in in_ports %}
        auto& src{{ loop.index }} = graph.emplaceBlock<gr::testing::ConstantSource<{{ first_port_type }}>>();
        src{{ loop.index }}.n_samples_max = 16U;
{% endfor %}
        auto& blk = graph.emplaceBlock<{{ namespace }}::{{ block_name }}<{{ first_type }}>>();
{% for port in out_ports %}
        auto& snk{{ loop.index }} = graph.emplaceBlock<gr::testing::NullSink<{{ first_out_type }}>>();
{% endfor %}
{% for port in in_ports %}
        expect(graph.connect<"out", "{{ port.name }}">(src{{ loop.index }}, blk).has_value());
{% endfor %}
{% for port in out_ports %}
        expect(graph.connect<"{{ port.name }}", "in">(blk, snk{{ loop.index }}).has_value());
{% endfor %}

        gr::scheduler::Simple sched;
        expect(sched.exchange(std::move(graph)).has_value());
        expect(sched.runAndWait().has_value());
    };
};
{% endif %}

int main() {}
