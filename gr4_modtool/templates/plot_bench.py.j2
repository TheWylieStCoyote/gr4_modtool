#!/usr/bin/env python3
"""Benchmark plot for {{ block_name }}.

Usage:
    python plot_{{ block_name }}.py [path/to/bench_{{ block_name }}]

The benchmark binary must be built first (cmake --build build).
Output CSV columns: block,config,N,throughput_MSas
"""

from __future__ import annotations

import csv
import subprocess
import sys
from pathlib import Path

try:
    import matplotlib.pyplot as plt
    _HAS_MPL = True
except ImportError:
    _HAS_MPL = False


def run_benchmark(binary: str) -> list[dict]:
    result = subprocess.run(
        [binary], capture_output=True, text=True, check=True
    )
    lines = [ln for ln in result.stdout.splitlines() if ln.strip()]
    return list(csv.DictReader(lines))


def plot(rows: list[dict]) -> None:
    if not _HAS_MPL:
        print("matplotlib not installed — printing CSV instead.")
        for row in rows:
            print(row)
        return

    configs = sorted({r["config"] for r in rows})
    block_names = [r["block"] for r in rows if r["config"] == configs[0]]

    x = range(len(block_names))
    bar_width = 0.8 / max(len(configs), 1)

    fig, ax = plt.subplots(figsize=(max(6, len(block_names) * 1.5), 5))
    for i, cfg_name in enumerate(configs):
        vals = [float(r["throughput_MSas"]) for r in rows if r["config"] == cfg_name]
        offsets = [xi + i * bar_width for xi in x]
        ax.bar(offsets, vals, width=bar_width, label=cfg_name)

    ax.set_xticks([xi + bar_width * (len(configs) - 1) / 2 for xi in x])
    ax.set_xticklabels(block_names, rotation=30, ha="right")
    ax.set_ylabel("Throughput (MSa/s)")
    ax.set_title("{{ block_name }} Benchmark")
    ax.legend()
    fig.tight_layout()

    out = Path("bench_{{ block_name }}.png")
    fig.savefig(out)
    print(f"Saved {out}")
    plt.show()


def main() -> None:
    binary = sys.argv[1] if len(sys.argv) > 1 else "./bench_{{ block_name }}"
    rows = run_benchmark(binary)
    plot(rows)


if __name__ == "__main__":
    main()
