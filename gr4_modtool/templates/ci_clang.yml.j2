name: C++ Lint

on:
  push:
    branches: [main, master, dev, "feat/**", "fix/**"]
  pull_request:
    branches: [main, master, dev, "feat/**", "fix/**"]

jobs:
  clang-format:
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - name: Install clang-format
        run: sudo apt-get install -y clang-format

      - name: Install gr4_modtool
        run: pip install gr4_modtool

      - name: Check formatting
        run: gr4_modtool format --check

  clang-tidy:
    runs-on: ubuntu-24.04
    steps:
      - uses: actions/checkout@v4

      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            clang-tidy cmake ninja-build pkg-config libfmt-dev
          # TODO: Install GNURadio 4 so cmake can configure successfully.
          #       See .devcontainer/Dockerfile for ready-to-use options.

      - name: Install gr4_modtool
        run: pip install gr4_modtool

      - name: Configure (generates compile_commands.json)
        run: >
          cmake -B build -S .
          -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
          -DENABLE_TESTING=OFF

      - name: Run clang-tidy
        run: gr4_modtool tidy --build-dir build
