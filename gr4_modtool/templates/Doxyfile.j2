# Doxyfile — generated by gr4_modtool for {{ project_name }}

PROJECT_NAME           = "{{ project_name }}"
PROJECT_NUMBER         = "{{ version }}"
PROJECT_BRIEF          = "GNURadio 4 OOT module"

OUTPUT_DIRECTORY       = docs/

INPUT                  = include/
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO

STRIP_FROM_PATH        = include/{{ gr4_include_prefix }}/
STRIP_FROM_INC_PATH    = include/

WARN_IF_UNDOCUMENTED   = NO

QUIET                  = YES
WARNINGS               = YES
